# Azure Terraform Backend Configuration - Development
# Copy to dev.tfbackend and customize with your values
#
# Usage:
#   terraform init -backend-config=backends/dev.tfbackend

resource_group_name  = "cudly-terraform-state-rg"
storage_account_name = "cudlytfstatedev"
container_name       = "tfstate"
key                  = "dev.terraform.tfstate"

# Note: Create the storage resources before first use:
#   az group create --name cudly-terraform-state-rg --location eastus
#   az storage account create --name cudlytfstatedev --resource-group cudly-terraform-state-rg --sku Standard_LRS
#   az storage container create --name tfstate --account-name cudlytfstatedev
