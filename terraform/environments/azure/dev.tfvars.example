# Azure Development Environment Variables
# Copy to dev.tfvars and customize with your values

# ==============================================
# Project Settings
# ==============================================

project_name = "cudly"
environment = "dev"

# ==============================================
# Azure Configuration
# ==============================================

subscription_id = "your-subscription-id"  # REQUIRED
location        = "eastus"

# ==============================================
# Compute Platform
# ==============================================

# Options: "container-apps" (serverless) or "aks" (kubernetes)
compute_platform = "container-apps"

# Container Apps settings
container_cpu            = 0.25
container_memory         = "0.5Gi"
min_replicas             = 0
max_replicas             = 10
external_ingress_enabled = true

# AKS settings (when compute_platform = "aks")
# aks_node_count   = 1
# aks_node_vm_size = "Standard_B2s"

# ==============================================
# Database (Azure Flexible Server PostgreSQL)
# ==============================================

postgres_version                = "16"
database_sku_name               = "B_Standard_B1ms"  # Basic tier for dev
database_storage_mb             = 32768
database_administrator_login    = "cudlyadmin"
database_backup_retention_days  = 7
database_geo_redundant_backup   = false
database_high_availability_mode = "Disabled"

# ==============================================
# Database Migration
# ==============================================

auto_migrate = true

# ==============================================
# Networking
# ==============================================

vnet_cidr                  = "10.0.0.0/16"
container_apps_subnet_cidr = "10.0.1.0/24"
database_subnet_cidr       = "10.0.2.0/24"

# ==============================================
# Key Vault (Secrets)
# ==============================================

key_vault_name             = "your-unique-kv-name"  # REQUIRED, globally unique
key_vault_sku              = "standard"
soft_delete_retention_days = 7
purge_protection_enabled   = false

# Dev environments are ephemeral; allow destroy through the resource group.
prevent_resource_group_deletion = false

# Dev allows unrestricted vault access; production should keep the default
# "Deny" and enumerate CI / operator IPs in allowed_ip_addresses.
key_vault_default_network_acl_action = "Allow"

# ==============================================
# Scheduled Tasks (Logic Apps)
# ==============================================
#
# Logic Apps fetch a shared bearer secret from Key Vault at invocation
# time and call /api/scheduled/* with `Authorization: Bearer <secret>`.
# The CUDly app validates via SCHEDULED_TASK_AUTH_MODE=bearer (set
# automatically by the container-apps / aks modules) — the secret name
# itself is wired through `module.secrets.scheduled_task_secret_name`
# and never lives in the container env.

enable_scheduled_tasks = true

# recommendation_schedule: a cron-shaped string, but ONLY the hour field
# (index [1]) is honored — the Azure module converts it into a Logic
# Apps recurrence trigger of frequency=Day + interval=1 starting at
# that hour (see modules/compute/azure/container-apps/scheduled-tasks.tf).
# Sub-daily / day-of-week / day-of-month patterns are silently ignored.
# Stick to daily-at-hour-N values; if you need finer granularity,
# extend the parser before pinning a different schedule.
recommendation_schedule = "0 2 * * *" # Daily at 02:00 UTC

# ==============================================
# Frontend (Azure CDN)
# ==============================================

enable_cdn = false

# ==============================================
# Docker Build
# ==============================================

enable_docker_build = true
image_uri           = "placeholder"  # unused when enable_docker_build = true

# ==============================================
# Email Service
# ==============================================

enable_email_service           = true
email_use_azure_managed_domain = true

# ==============================================
# Admin
# ==============================================

admin_email = "admin@example.com"
# Leave empty or omit to auto-generate a random password stored in Key Vault.
# To retrieve the generated password:
#   az keyvault secret show \
#     --vault-name <your-vault-name> --name admin-password \
#     --query value --output tsv
# admin_password = "YourSecurePassword123!"
