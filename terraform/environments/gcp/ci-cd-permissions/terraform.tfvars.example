# GCP CI/CD Permissions - example tfvars
# Copy to terraform.tfvars and fill in your values.
#
# Prerequisites: gcloud CLI authenticated (gcloud auth application-default login)
# with an account that has Project IAM Admin on the target project.
#
# ─── project_id ────────────────────────────────────────────────────────────────
# The GCP project where the cudly-terraform-deploy service account will be
# created and granted the necessary roles.
#
# List projects you have access to:
#   gcloud projects list --format="table(projectId,name)"
#
# Show the currently active project:
#   gcloud config get-value project
#
# Get the project ID from a project number:
#   gcloud projects describe <PROJECT_NUMBER> --format="value(projectId)"
#
project_id = "your-gcp-project-id"

# ─── github_repo ───────────────────────────────────────────────────────────────
# GitHub repository (owner/name) whose Actions workflows may impersonate the
# deploy service account via Workload Identity Federation (keyless — no JSON
# key files needed).
#
# Creates a WIF pool + OIDC provider and binds the SA with
# roles/iam.workloadIdentityUser restricted to the specified repository.
#
# Set to "" to skip WIF setup.
#
github_repo = "LeanerCloud/CUDly"

# ─── deploy_ref ────────────────────────────────────────────────────────────────
# Git ref whose workflows are permitted to impersonate the deploy SA.
# Only exact-match pushes to this branch can obtain a GCP token.
# PRs, tags, forks, and workflow_dispatch from other refs are blocked.
#
# DEFAULT: refs/heads/main
# The default in variables.tf is refs/heads/main, which is correct for normal
# operation. Override here ONLY when temporarily deploying from a feature branch.
#
# IMPORTANT: When the active deploy branch changes (e.g. a long-running feature
# branch merges into main), update this value and re-apply the module. Forgetting
# to flip back to refs/heads/main will lock out all future main-branch deploys
# with: "The given credential is rejected by the attribute condition."
#
# To verify the currently-applied condition in GCP (read-only):
#   gcloud iam workload-identity-pools providers describe github-actions \
#     --workload-identity-pool=github-actions --location=global \
#     --project=<PROJECT_ID> --format="value(attributeCondition)"
#
deploy_ref = "refs/heads/main"
