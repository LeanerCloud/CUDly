# AWS Fargate Development Profile
# Copy to fargate-dev.tfvars and customize with your values

# Project identification
project_name = "cudly"
environment  = "fargate-dev"

# Cloud configuration
region = "us-east-1"
# aws_profile = "your-aws-profile"

# Compute platform
compute_platform = "fargate"

# Fargate configuration
fargate_cpu           = 512
fargate_memory        = 1024
fargate_desired_count = 1
fargate_min_capacity  = 1
fargate_max_capacity  = 4
# fargate_certificate_arn = "arn:aws:acm:..."  # Only needed if not using subdomain_zone_name

# Docker build settings
enable_docker_build = true

# Admin
admin_email = "admin@example.com"

# Database (RDS PostgreSQL)
database_name                  = "cudly"
database_username              = "cudly"
database_engine_version        = "16.6"
database_backup_retention_days = 7
database_deletion_protection   = false
database_skip_final_snapshot   = true
database_performance_insights  = false
database_auto_migrate          = true

# Networking
vpc_cidr         = "10.0.0.0/16"
az_count         = 2
enable_flow_logs = false

# Secrets
secret_recovery_window_days = 7

# Frontend
enable_cdn           = false
frontend_price_class = "PriceClass_100"

# Scheduled tasks
enable_scheduled_tasks  = true
recommendation_schedule = "rate(1 day)"
