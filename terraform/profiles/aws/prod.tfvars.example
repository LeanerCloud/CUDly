# AWS Production Profile
# Copy to prod.tfvars and customize with your values

# Project identification
project_name = "cudly"
environment  = "prod"

# Cloud configuration
provider = "aws"
region   = "us-east-1"
# aws_profile = "your-aws-profile"  # Set TF_VAR_aws_profile env var

# Compute platform
compute_platform = "lambda"  # or "fargate"
architecture     = "arm64"   # Graviton for cost savings
memory_size      = 1024      # More memory for production

# Docker build settings
skip_docker_build    = false
skip_docker_push     = false
docker_platform      = "linux/arm64"
cleanup_old_images   = true

# Database
database_name                    = "cudly"
database_username                = "cudly"
database_engine_version          = "16.4"
database_min_capacity            = 2.0   # Higher minimum for prod
database_max_capacity            = 8.0   # Higher max for prod
database_backup_retention_days   = 30    # Longer retention for prod
database_deletion_protection     = true  # Protect against deletion
database_skip_final_snapshot     = false # Create final snapshot
database_auto_migrate            = true
database_high_availability       = true

# Networking
vpc_cidr = "10.0.0.0/16"
az_count = 3  # More AZs for production

# Frontend
enable_frontend_build = true

# Features
enable_dashboard = true
enable_scheduled_tasks = true

# Monitoring
enable_monitoring = true  # Full monitoring in production

# Secrets
secret_recovery_window_days = 30

# Tags
tags = {
  Environment = "prod"
  ManagedBy   = "terraform"
  Project     = "cudly"
  Owner       = "platform"
  CostCenter  = "production"
}
