# AWS Lambda Development Profile
# Copy to dev.tfvars and customize with your values

# Project identification
project_name = "cudly"
environment  = "dev"

# Cloud configuration
provider = "aws"
region   = "us-east-1"
# aws_profile = "your-aws-profile"  # Set TF_VAR_aws_profile env var

# Compute platform
compute_platform = "lambda"
architecture     = "arm64"  # Graviton for cost savings
memory_size      = 512      # 512 MB

# Docker build settings
skip_docker_build    = false
skip_docker_push     = false
docker_platform      = "linux/arm64"
cleanup_old_images   = true

# Database
database_name                    = "cudly"
database_username                = "cudly"
database_engine_version          = "16.4"
database_min_capacity            = 0.5   # Minimum for dev
database_max_capacity            = 2.0   # Max for dev
database_backup_retention_days   = 7
database_deletion_protection     = false # Allow deletion in dev
database_skip_final_snapshot     = true  # Skip snapshot in dev
database_auto_migrate            = true

# Networking
vpc_cidr = "10.0.0.0/16"
az_count = 2

# Frontend
enable_frontend_build = true

# Features
enable_dashboard = true
enable_scheduled_tasks = true

# Monitoring
enable_monitoring = false  # Reduced monitoring in dev

# Secrets
secret_recovery_window_days = 7

# Tags
tags = {
  Environment = "dev"
  ManagedBy   = "terraform"
  Project     = "cudly"
  Owner       = "devteam"
}
