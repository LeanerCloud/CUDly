#!/usr/bin/env bash
# Create CUDly GCP Workload Identity Pool + OIDC provider bound to
# CUDly's own OIDC issuer, plus grant the target service account
# workloadIdentityUser to the "cudly-controller" subject.
#
# Target GCP project : {{.AccountName}} ({{.ProjectID}})
#
# This script configures true secret-free federation: CUDly's OIDC
# issuer (served under {{.CUDlyAPIURL}}/oidc, backed by AWS KMS /
# Azure Key Vault / GCP Cloud KMS depending on where CUDly runs)
# signs a short-lived JWT on each GCP API call and Google STS
# verifies it against the JWKS published by the CUDly deployment.
# No keys, no credential JSON, nothing to rotate on the CUDly side.
#
# Usage:
#   CUDLY_CONTACT_EMAIL=ops@example.com bash {{.AccountSlug}}-gcp-wif-cli.sh
#
# Requirements: gcloud CLI authenticated with a principal that has
# IAM admin on the project.
set -euo pipefail

PROJECT_ID="${PROJECT_ID:-{{.ProjectID}}}"
SERVICE_ACCOUNT_EMAIL="${SERVICE_ACCOUNT_EMAIL:-{{.ServiceAccountEmail}}}"
POOL_ID="${POOL_ID:-cudly-{{.AccountSlug}}}"
PROVIDER_ID="${PROVIDER_ID:-cudly-oidc}"

# CUDly OIDC issuer URL — base URL + /oidc. Google STS appends
# /.well-known/openid-configuration when resolving the discovery
# document, so do NOT include the well-known suffix here.
CUDLY_ISSUER_URL="${CUDLY_ISSUER_URL:-{{.CUDlyAPIURL}}/oidc}"
CUDLY_FEDERATED_SUBJECT="${CUDLY_FEDERATED_SUBJECT:-cudly-controller}"

: "${PROJECT_ID:?set PROJECT_ID to the target GCP project}"
: "${SERVICE_ACCOUNT_EMAIL:?set SERVICE_ACCOUNT_EMAIL to the CUDly target service account in the project}"
: "${CUDLY_ISSUER_URL:?set CUDLY_ISSUER_URL to the OIDC issuer URL of your CUDly deployment (base URL + /oidc)}"

gcloud config set project "${PROJECT_ID}"

echo "Enabling required APIs..."
gcloud services enable iam.googleapis.com iamcredentials.googleapis.com sts.googleapis.com

echo "Creating Workload Identity Pool ${POOL_ID}..."
gcloud iam workload-identity-pools create "${POOL_ID}" \
  --location=global \
  --display-name="CUDly WIF pool" \
  --project="${PROJECT_ID}" \
  || echo "  (pool may already exist)"

echo "Creating OIDC provider ${PROVIDER_ID} bound to CUDly issuer..."
gcloud iam workload-identity-pools providers create-oidc "${PROVIDER_ID}" \
  --location=global \
  --workload-identity-pool="${POOL_ID}" \
  --issuer-uri="${CUDLY_ISSUER_URL}" \
  --attribute-mapping="google.subject=assertion.sub" \
  --attribute-condition="assertion.sub == '${CUDLY_FEDERATED_SUBJECT}'" \
  --project="${PROJECT_ID}" \
  || echo "  (provider may already exist)"

# WIF pool creation is eventually consistent — retry describe briefly
for _attempt in 1 2 3 4 5; do
  POOL_NAME=$(gcloud iam workload-identity-pools describe "${POOL_ID}" --location=global --project="${PROJECT_ID}" --format="value(name)" 2>/dev/null) && break
  echo "  Waiting for WIF pool to propagate (attempt ${_attempt})..."
  sleep 5
done
: "${POOL_NAME:?WIF pool describe failed after retries}"

# POOL_NAME is "projects/<number>/locations/global/workloadIdentityPools/<pool>"
# The full WIF audience CUDly uses as the STS audience is the
# provider resource, prefixed with //iam.googleapis.com/
WIF_AUDIENCE="//iam.googleapis.com/${POOL_NAME}/providers/${PROVIDER_ID}"

echo "Granting workloadIdentityUser on ${SERVICE_ACCOUNT_EMAIL} to ${CUDLY_FEDERATED_SUBJECT}..."
gcloud iam service-accounts add-iam-policy-binding "${SERVICE_ACCOUNT_EMAIL}" \
  --role=roles/iam.workloadIdentityUser \
  --member="principal://iam.googleapis.com/${POOL_NAME}/subject/${CUDLY_FEDERATED_SUBJECT}" \
  --project="${PROJECT_ID}" \
  --format="none"

echo ""
echo "=== Done ==="
echo "project_id            : ${PROJECT_ID}"
echo "pool_name             : ${POOL_NAME}"
echo "provider_id           : ${PROVIDER_ID}"
echo "service_account_email : ${SERVICE_ACCOUNT_EMAIL}"
echo "wif_audience          : ${WIF_AUDIENCE}"
echo ""
echo "In CUDly, set gcp_auth_mode = workload_identity_federation. No JSON config file or keys are required — CUDly mints and signs the subject token itself on each call."

{{- if .CUDlyAPIURL}}
if [[ -n "${CUDLY_CONTACT_EMAIL:-}" ]]; then
  echo ""
  echo "Registering account with CUDly..."
  ACCOUNT_NAME="${CUDLY_ACCOUNT_NAME:-GCP ${PROJECT_ID}}"
  read -r -d '' PAYLOAD <<JSON || true
{
  "provider": "gcp",
  "external_id": "${PROJECT_ID}",
  "account_name": "${ACCOUNT_NAME}",
  "contact_email": "${CUDLY_CONTACT_EMAIL}",
  "gcp_auth_mode": "workload_identity_federation",
  "gcp_project_id": "${PROJECT_ID}",
  "gcp_client_email": "${SERVICE_ACCOUNT_EMAIL}",
  "gcp_wif_audience": "${WIF_AUDIENCE}"
}
JSON
  HTTP_CODE=$(curl -sS -o /tmp/cudly-register.out -w "%{http_code}" \
    -X POST "{{.CUDlyAPIURL}}/api/register" \
    -H "Content-Type: application/json" \
    -d "${PAYLOAD}")
  case "$HTTP_CODE" in
    200|201) echo "Registration submitted. Reference token: $(jq -r .reference_token /tmp/cudly-register.out 2>/dev/null || cat /tmp/cudly-register.out)" ;;
    409)     echo "Registration already pending for this account — continuing." ;;
    *)       echo "WARNING: CUDly registration returned HTTP $HTTP_CODE:"; cat /tmp/cudly-register.out ;;
  esac
fi
{{- end}}
