# Terraform variables for iac/federation/gcp-target/terraform
# Target GCP project : {{.AccountName}} ({{.ProjectID}})
# Source cloud       : {{.Source}}
#
# Usage:
#   cd iac/federation/gcp-target/terraform
#   terraform init
#   terraform apply -var-file={{.AccountSlug}}-gcp-wif.tfvars
#
# After apply, run the gcloud_command output to generate the external account
# credential JSON, then paste it into CUDly as gcp_workload_identity_config.

project = "{{.ProjectID}}"

# service_account_email — leave empty (default) to have Terraform create a
# dedicated least-privilege SA (name: service_account_id, default "cudly-wif")
# with commitment-management roles. Set to an existing SA email to reuse it
# instead — in that case, grant the required roles yourself.
service_account_email = "{{.ServiceAccountEmail}}"
{{- if eq .Source "aws"}}
provider_type  = "aws"
aws_account_id = "{{.SourceAccountID}}"  # AWS account number where CUDly runs
{{- else}}
provider_type   = "oidc"
oidc_issuer_uri = "{{.OIDCIssuerURI}}"{{if eq .Source "azure"}}  # Azure: https://login.microsoftonline.com/<TENANT_ID>/v2.0{{end}}
{{- end}}
{{- if eq .Source "aws"}}
# aws_role_name = ""  # Recommended: restrict to specific IAM role (e.g. "CUDly-WIF")
{{- else}}
# oidc_subject  = ""  # Recommended: restrict to specific OIDC subject
{{- end}}

# --- CUDly auto-registration (optional) ---
cudly_api_url = "{{.CUDlyAPIURL}}"
contact_email = "{{.ContactEmail}}"
account_name  = "{{.AccountName}}"
